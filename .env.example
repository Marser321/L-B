# Server-only HighLevel configuration. Never commit real values.
GHL_PRIVATE_TOKEN=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=
GHL_CONFIRMED_PIPELINE_STAGE_ID=
GHL_CALENDAR_ID=
GHL_ASSIGNED_USER_ID=
# Crews that can take a website booking, as a comma-separated list of user IDs.
# Availability offers a start time when ANY listed crew is free, so two ids means
# two simultaneous bookings. Defaults to GHL_ASSIGNED_USER_ID when unset.
GHL_CREW_USER_IDS=
# Optional Inbound Webhook that a workflow listens to after each booking.
GHL_BOOKING_WEBHOOK_URL=
# Phase B — online deposit collection. Off unless set to exactly "on"; when off,
# behavior is byte-for-byte identical to Phase A (no payment API calls, no new
# response fields, no deposit custom-field values). See PHASE-B-DECISIONS.md.
GHL_DEPOSIT_PAYMENTS=
# Set to exactly "true" to charge the deposit through Stripe LIVE mode. Any other
# value (including unset) uses Stripe TEST mode, so turning GHL_DEPOSIT_PAYMENTS
# on can never move real money by accident.
GHL_DEPOSIT_LIVE_MODE=
